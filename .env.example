# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
# Get these values from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# PostgreSQL Database URL (from Supabase Connection Pooling)
# Replace [project-ref] and [password] with your Supabase project details
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# =============================================================================
# RAYA AI ASSISTANT CONFIGURATION
# =============================================================================
# AI Provider: openai, gemini, claude, openrouter
AI_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Gemini Configuration (alternative)
# GOOGLE_GENERATIVE_API_KEY=your-gemini-api-key

# Claude Configuration (alternative)
# ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenRouter Configuration (alternative)
# OPENROUTER_API_KEY=your-openrouter-api-key

# =============================================================================
# SECURITY SETTINGS (Optional)
# =============================================================================

# Rate limiting - requests per minute per IP (default: 100)
# RATE_LIMIT_REQUESTS=100

# Enable/disable features based on environment
NEXT_PUBLIC_ENVIRONMENT=development

