// =============================================================================
// Sri Raghavendra Swamy Temple - Database Schema
// Domain Model v5 - Sprint 2.2.1 - Final Architecture
// =============================================================================

generator client {
  previewFeatures = ["driverAdapters"]
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// USER MANAGEMENT - RBAC (Profile + Role + UserRole)
// =============================================================================

/// User Profile - linked to Supabase Auth
model Profile {
  id      String  @id @default(uuid())
  userId  String  @unique
  email   String  @unique
  name    String?
  phone   String?
  address String?

  // Media - Avatar
  avatarId String?
  avatar   Media?  @relation("ProfileAvatars", fields: [avatarId], references: [id])

  emailVerified Boolean   @default(false)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  donations     Donation[]
  bookings      Booking[]
  announcements Announcement[]
  testimonial   Testimonial?
  chatFeedback  ChatFeedback[]
  userRoles     UserRole[]

  @@index([email])
  @@index([isActive])
  @@map("profiles")
}

/// Role definition
model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  permissions String[] // Array of permission strings

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userRoles UserRole[]

  @@map("roles")
}

/// User-Role association (many-to-many)
model UserRole {
  id        String @id @default(uuid())
  profileId String
  roleId    String

  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([profileId, roleId])
  @@map("user_roles")
}

// =============================================================================
// TEMPLE CONFIGURATION
// =============================================================================

/// Temple Information
model TempleInfo {
  id String @id @default(uuid())

  // Basic Info
  name        String
  shortName   String?
  tagline     String?
  description String?

  // Address
  address  String?
  city     String?
  district String?
  state    String?
  country  String  @default("India")
  pincode  String?

  // Contact
  phone          String?
  alternatePhone String?
  email          String?
  website        String?

  // Location
  mapEmbedUrl String?
  latitude    Float?
  longitude   Float?

  // Social Media
  socialFacebook  String?
  socialTwitter   String?
  socialInstagram String?
  socialYoutube   String?
  socialWhatsapp  String?

  // Bank Details for Donations
  bankName          String?
  bankAccountName   String?
  bankAccountNumber String?
  bankIFSCCode      String?
  bankUPIId         String?

  // Statistics
  establishedYear Int?
  priestCount     Int?
  dailyVisitors   Int?

  // Media - Logo and Favicon
  logoId    String?
  logo      Media?  @relation("TempleLogos", fields: [logoId], references: [id])
  faviconId String?
  favicon   Media?  @relation("TempleFavicons", fields: [faviconId], references: [id])

  // Audit fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("temple_info")
}

/// Site-wide Settings (Key-Value Store)
model SiteSetting {
  id          String  @id @default(uuid())
  key         String  @unique
  value       String  @db.Text
  description String?
  category    String? // "general", "seo", "social", "email", etc.
  isPublic    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@map("site_settings")
}

// =============================================================================
// HOMEPAGE CONFIGURATION
// =============================================================================

/// Homepage Configuration
model HomepageConfig {
  id String @id @default(uuid())

  // Hero Section
  heroTitle               String?
  heroSubtitle            String?
  heroVideoUrl            String?
  heroPrimaryButtonText   String?
  heroPrimaryButtonUrl    String?
  heroSecondaryButtonText String?
  heroSecondaryButtonUrl  String?

  // Media - Hero Image
  heroImageId String?
  heroImage   Media?  @relation("HomepageHeroImages", fields: [heroImageId], references: [id])

  // About Section
  aboutTitle   String?
  aboutContent String? @db.Text

  // Media - About Image
  aboutImageId String?
  aboutImage   Media?  @relation("HomepageAboutImages", fields: [aboutImageId], references: [id])

  // Section Visibility
  showFeaturedEvents  Boolean @default(true)
  showFeaturedSevas   Boolean @default(true)
  showDonationSection Boolean @default(true)
  showGalleryPreview  Boolean @default(true)
  showAnnouncements   Boolean @default(true)
  showTestimonials    Boolean @default(true)
  showPanchanga       Boolean @default(true)

  // Limits
  featuredEventsLimit Int @default(6)
  featuredSevasLimit  Int @default(8)
  galleryPreviewLimit Int @default(8)
  testimonialLimit    Int @default(5)

  // Donation Section
  donationTitle    String?
  donationSubtitle String?

  // Announcement Banner
  announcementBannerText String?
  announcementBannerUrl  String?

  // Footer
  footerCopyright String?
  footerTagline   String?

  // Audit fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("homepage_configs")
}

// =============================================================================
// TEMPLE SCHEDULE (TempleDay + TempleException)
// =============================================================================

/// Regular Temple Days
model TempleDay {
  id        String  @id @default(uuid())
  dayOfWeek Int // 0=Sunday, 1=Monday, etc.
  name      String? // e.g., "Sunday", "Monday"

  // Morning timings
  morningOpenTime  String? // e.g., "05:00"
  morningCloseTime String? // e.g., "13:00"

  // Evening timings
  eveningOpenTime  String?
  eveningCloseTime String?

  // Special notes
  notes String?

  // Status
  isHoliday Boolean @default(false)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dayOfWeek])
  @@map("temple_days")
}

/// Temple Schedule Exceptions (Special days, holidays, closures)
model TempleException {
  id String @id @default(uuid())

  date        DateTime
  name        String? // e.g., "Diwali", "Special Festival"
  description String?

  // Override timings (null means closed)
  morningOpenTime  String?
  morningCloseTime String?
  eveningOpenTime  String?
  eveningCloseTime String?

  // Status
  isClosed       Boolean @default(false)
  isSpecialEvent Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@map("temple_exceptions")
}

// =============================================================================
// CENTRALIZED MEDIA
// =============================================================================

/// Media Library (centralized media storage)
model Media {
  id String @id @default(uuid())

  // File Info
  filename     String
  originalName String?
  mimeType     String?
  fileSize     Int? // bytes

  // Storage
  bucket      String @default("media")
  storagePath String // Path in Supabase Storage

  // Metadata
  title       String?
  altText     String?
  caption     String?
  description String?

  // Classification
  type     MediaType @default(IMAGE)
  category String? // "events", "gallery", "poojas", "aaradhanes", etc.

  // Media-specific fields
  width    Int?
  height   Int?
  duration Int? // seconds (for audio/video)

  // Status
  isPublic   Boolean @default(true)
  isFeatured Boolean @default(false)
  isActive   Boolean @default(true)

  // Usage tracking
  viewCount     Int @default(0)
  downloadCount Int @default(0)

  // Upload info
  uploadedBy String?

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations - Event
  eventImages  Event[] @relation("EventImages")
  eventBanners Event[] @relation("EventBanners")

  // Relations - Aaradhane
  aaradhaneImages Aaradhane[] @relation("AaradhaneImages")
  aaradhaneThumbs Aaradhane[] @relation("AaradhaneThumbnails")

  // Relations - Seva
  sevaImages Seva[] @relation("SevaImages")

  // Relations - Donation
  donationImages DonationCampaign[] @relation("DonationImages")

  // Relations - Committee
  committeeImages CommitteeMember[] @relation("CommitteeImages")

  // Relations - Gallery
  galleryImages    GalleryItem[]
  albumCoverImages GalleryAlbum[] @relation("AlbumCoverImages")

  // Relations - PoojaSchedule
  poojaImages PoojaSchedule[]

  // Relations - Facility
  facilityImages Facility[]

  // Relations - Testimonial
  testimonialImages Testimonial[]

  // Relations - Homepage
  homepageHeroImages  HomepageConfig[] @relation("HomepageHeroImages")
  homepageAboutImages HomepageConfig[] @relation("HomepageAboutImages")

  // Relations - Profile
  profileAvatars Profile[] @relation("ProfileAvatars")

  // Relations - Temple
  templeLogos    TempleInfo[] @relation("TempleLogos")
  templeFavicons TempleInfo[] @relation("TempleFavicons")

  // Relations - Knowledge
  articleImages   KnowledgeArticle[]    @relation("ArticleImages")
  attachmentFiles KnowledgeAttachment[]

  // Relations - Document
  documentFiles Document[]

  @@index([type, isActive])
  @@index([category])
  @@index([isFeatured])
  @@map("media")
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

// =============================================================================
// ANNOUNCEMENTS
// =============================================================================

model Announcement {
  id      String  @id @default(uuid())
  title   String
  content String  @db.Text
  excerpt String?

  type     AnnouncementType @default(GENERAL)
  priority Priority         @default(NORMAL)

  isPinned  Boolean   @default(false)
  isActive  Boolean   @default(true)
  expiresAt DateTime?

  authorId String?
  author   Profile? @relation(fields: [authorId], references: [id])

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([isActive, expiresAt])
  @@index([type])
  @@index([priority])
  @@map("announcements")
}

enum AnnouncementType {
  GENERAL
  EVENT
  DONATION
  FESTIVAL
  MAINTENANCE
  URGENT
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// =============================================================================
// EVENTS & CALENDAR
// =============================================================================

/// Temple Events
model Event {
  id      String  @id @default(uuid())
  title   String
  titleKn String? // Kannada

  description   String? @db.Text
  descriptionKn String? @db.Text

  startDate DateTime
  endDate   DateTime
  startTime String?
  endTime   String?

  location   String?
  isOnline   Boolean @default(false)
  onlineLink String?

  type   EventType   @default(GENERAL)
  status EventStatus @default(UPCOMING)

  featured  Boolean @default(false)
  published Boolean @default(false)

  // Media
  imageId  String?
  image    Media?  @relation("EventImages", fields: [imageId], references: [id])
  bannerId String?
  banner   Media?  @relation("EventBanners", fields: [bannerId], references: [id])

  maxAttendees     Int?
  currentAttendees Int  @default(0)

  organizer    String?
  contactPhone String?
  contactEmail String?

  // Audit fields
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  // Relations
  bookingItems BookingItem[]
  galleryItems GalleryItem[]
  albums       GalleryAlbum[] @relation("AlbumFestivals")

  @@index([startDate, published])
  @@index([status])
  @@index([type])
  @@map("events")
}

enum EventType {
  GENERAL
  FESTIVAL
  WORKSHOP
  SPIRITUAL
  CULTURAL
  MAINTENANCE
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

/// Festivals
model Festival {
  id     String  @id @default(uuid())
  name   String
  nameKn String?

  date    DateTime
  endDate DateTime?

  description   String? @db.Text
  descriptionKn String? @db.Text
  significance  String? @db.Text

  // Media
  imageUrl String?

  isMajorFestival Boolean @default(false)
  isHoliday       Boolean @default(true)

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([date])
  @@map("festivals")
}

/// Panchanga (Daily Calendar Data)
model Panchanga {
  id   String   @id @default(uuid())
  date DateTime @unique

  // Tithis
  tithi    String
  tithiEnd String?

  // Nakshatras
  nakshatra    String
  nakshatraEnd String?

  // Yoga
  yoga    String
  yogaEnd String?

  // Karana
  karana    String
  karanaEnd String?

  // Sun & Moon
  sunrise   String
  sunset    String
  moonrise  String?
  moonset   String?
  moonPhase String?

  // Auspicious Times
  brahmaMuhurta String?
  amritaKaalam  String?
  sunriseKaalam String?
  sunsetKaalam  String?

  // Rahukalam & Yamaganda
  rahukalam   String?
  yamaganda   String?
  durMuhurtam String?

  notes String?

  // Audit fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@map("panchangas")
}

/// Daily Pooja Schedule
model PoojaSchedule {
  id     String  @id @default(uuid())
  name   String
  nameKn String?

  time          String
  description   String?
  descriptionKn String?

  category  String? // "Morning", "Afternoon", "Evening", "Special"
  isSpecial Boolean @default(false)

  // Media
  imageId String?
  image   Media?  @relation(fields: [imageId], references: [id])

  active Boolean @default(true)
  order  Int     @default(0)

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([active, order])
  @@index([category])
  @@map("pooja_schedules")
}

// =============================================================================
// UNIFIED BOOKING SYSTEM (Booking + BookingItem)
// =============================================================================

/// Unified Booking
model Booking {
  id String @id @default(uuid())

  // Booking Reference
  referenceNumber String @unique

  // User Info
  profileId String?
  profile   Profile? @relation(fields: [profileId], references: [id])

  // Guest Info (for non-logged in users)
  guestName  String?
  guestEmail String?
  guestPhone String?

  // Booking Details
  bookingType   BookingType
  bookingDate   DateTime
  preferredTime String?

  // Status
  status BookingStatus @default(PENDING)

  // Financial - using Decimal for monetary values
  totalAmount Decimal @default(0) @db.Decimal(12, 2)
  currency    String  @default("INR")
  paidAmount  Decimal @default(0) @db.Decimal(12, 2)

  // Devotee Info (for religious bookings)
  devoteeName String?
  gothra      String?
  nakshatra   String?
  gotraKn     String?

  // Notes
  notes      String? @db.Text
  adminNotes String? @db.Text

  // Receipt
  receiptNumber String?
  receiptUrl    String?

  // Audit fields
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  // Relations
  items BookingItem[]

  @@index([profileId])
  @@index([bookingType, bookingDate])
  @@index([status])
  @@map("bookings")
}

enum BookingType {
  SEVA
  EVENT
  DONATION
  OTHER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  REFUNDED
}

/// Booking Items (supports multiple items per booking)
model BookingItem {
  id        String @id @default(uuid())
  bookingId String

  // Explicit foreign keys instead of polymorphic itemType/itemId
  sevaId      String?
  aaradhaneId String?
  eventId     String?

  // Item Details (denormalized for historical record)
  itemName   String
  itemNameKn String?

  // Quantity and Price - using Decimal for monetary values
  quantity   Int     @default(1)
  unitPrice  Decimal @default(0) @db.Decimal(12, 2)
  totalPrice Decimal @default(0) @db.Decimal(12, 2)

  // Date/Time
  requestedDate DateTime?
  requestedTime String?

  // Status
  status BookingStatus @default(CONFIRMED)

  // Additional Info
  notes String? @db.Text

  // Audit fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  booking   Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  seva      Seva?      @relation(fields: [sevaId], references: [id])
  aaradhane Aaradhane? @relation(fields: [aaradhaneId], references: [id])
  event     Event?     @relation(fields: [eventId], references: [id])

  @@index([bookingId])
  @@index([sevaId])
  @@index([aaradhaneId])
  @@index([eventId])
  @@map("booking_items")
}

// =============================================================================
// SEVAS (SERVICES)
// =============================================================================

/// Seva Types
model Seva {
  id String @id @default(uuid())

  name          String
  nameKn        String?
  description   String? @db.Text
  descriptionKn String? @db.Text

  // Monetary - using Decimal
  price    Decimal @default(0) @db.Decimal(12, 2)
  currency String  @default("INR")

  duration String? // e.g., "30 minutes", "1 hour"

  category String? // "Daily", "Special", "Premium"

  // Media
  imageId  String?
  image    Media?  @relation("SevaImages", fields: [imageId], references: [id])
  iconName String?

  active   Boolean @default(true)
  featured Boolean @default(false)

  maxPerDay         Int? // Maximum bookings per day
  minAdvanceBooking Int? // Minimum days in advance
  maxAdvanceBooking Int? // Maximum days in advance

  instructions String? @db.Text
  benefits     String? @db.Text

  order Int @default(0)

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  bookingItems   BookingItem[]
  aaradhaneSevas AaradhaneSeva[]

  @@index([active, featured])
  @@index([category])
  @@map("sevas")
}

// =============================================================================
// AARADHANE (SPECIAL POOJAS)
// =============================================================================

/// Aaradhane (Special Poojas/Deities)
model Aaradhane {
  id String @id @default(uuid())

  title   String
  titleKn String?

  deityName String?
  guruName  String?

  description  String? @db.Text
  significance String? @db.Text

  startDate DateTime?
  endDate   DateTime?

  // Media
  imageId     String?
  image       Media?  @relation("AaradhaneImages", fields: [imageId], references: [id])
  thumbnailId String?
  thumbnail   Media?  @relation("AaradhaneThumbnails", fields: [thumbnailId], references: [id])

  rituals   String[] // Array of ritual names
  offerings String[] // Array of offerings

  featured Boolean @default(false)
  active   Boolean @default(true)
  order    Int     @default(0)

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  bookingItems BookingItem[]
  sevas        AaradhaneSeva[]

  @@index([featured, active])
  @@map("aaradhanes")
}

/// Aaradhane Seva (Associated Sevas)
model AaradhaneSeva {
  id          String @id @default(uuid())
  aaradhaneId String

  name        String
  nameKn      String?
  description String? @db.Text

  // Monetary - using Decimal
  amount   Decimal @default(0) @db.Decimal(12, 2)
  currency String  @default("INR")

  active Boolean @default(true)
  order  Int     @default(0)

  // Audit fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  aaradhane Aaradhane @relation(fields: [aaradhaneId], references: [id], onDelete: Cascade)
  seva      Seva?     @relation(fields: [sevaId], references: [id])
  sevaId    String?

  @@index([aaradhaneId])
  @@map("aaradhane_sevas")
}

// =============================================================================
// DONATIONS
// =============================================================================

/// Donation Campaigns
model DonationCampaign {
  id String @id @default(uuid())

  title         String
  titleKn       String?
  description   String? @db.Text
  descriptionKn String? @db.Text

  // Monetary - using Decimal
  targetAmount Decimal? @db.Decimal(12, 2)
  raisedAmount Decimal  @default(0) @db.Decimal(12, 2)
  currency     String   @default("INR")

  // Media
  imageId  String?
  image    Media?  @relation("DonationImages", fields: [imageId], references: [id])
  videoUrl String?

  active   Boolean @default(true)
  featured Boolean @default(false)

  startDate DateTime?
  endDate   DateTime?

  urgencyLevel UrgencyLevel @default(NORMAL)

  category String? // "Development", "Maintenance", "Charity", "Temple Fund"

  createdBy String?

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  donations Donation[]

  @@index([active, featured])
  @@index([urgencyLevel])
  @@map("donation_campaigns")
}

enum UrgencyLevel {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

/// Donations
model Donation {
  id String @id @default(uuid())

  // User
  profileId String?
  profile   Profile? @relation(fields: [profileId], references: [id])

  // Campaign
  campaignId String?
  campaign   DonationCampaign? @relation(fields: [campaignId], references: [id])

  // Monetary - using Decimal
  amount   Decimal @db.Decimal(12, 2)
  currency String  @default("INR")

  // Payment
  paymentMethod PaymentMethod?
  paymentId     String?
  transactionId String?
  status        DonationStatus @default(PENDING)

  // Donor Info
  donorName    String
  donorEmail   String
  donorPhone   String?
  donorAddress String?
  anonymous    Boolean @default(false)

  message    String?
  dedication String?

  // Receipt
  receiptNumber String?
  receiptUrl    String?

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  payments DonationPayment[]

  @@index([profileId])
  @@index([campaignId])
  @@index([status])
  @@index([createdAt])
  @@unique([receiptNumber])
  @@map("donations")
}

enum PaymentMethod {
  CARD
  UPI
  NET_BANKING
  WALLET
  BANK_TRANSFER
  CASH
  CHEQUE
}

enum DonationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

/// Donation Payment Attempts
model DonationPayment {
  id         String @id @default(uuid())
  donationId String

  // Monetary - using Decimal
  amount   Decimal @db.Decimal(12, 2)
  currency String  @default("INR")

  paymentMethod PaymentMethod
  paymentId     String?
  transactionId String?

  status PaymentAttemptStatus @default(PENDING)

  responseData Json?
  errorMessage String?

  attemptedAt DateTime  @default(now())
  completedAt DateTime?

  donation Donation @relation(fields: [donationId], references: [id], onDelete: Cascade)

  @@index([donationId])
  @@index([status])
  @@map("donation_payments")
}

enum PaymentAttemptStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  REFUNDED
}

// =============================================================================
// GALLERY
// =============================================================================

/// Gallery Items
model GalleryItem {
  id String @id @default(uuid())

  title         String?
  titleKn       String?
  description   String?
  descriptionKn String?

  // Media
  mediaId String
  media   Media  @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  // Event association
  eventId String?
  event   Event?  @relation(fields: [eventId], references: [id])

  // Type (PHOTO or VIDEO)
  type GalleryItemType @default(PHOTO)

  // Display settings
  altText    String?
  caption    String?
  captionKn  String?

  // Album association via junction
  albums AlbumItem[]

  featured   Boolean @default(false)
  showOnHome Boolean @default(false)
  active     Boolean @default(true)

  // Display
  displayOrder Int @default(0)
  order        Int @default(0)

  // Exif/Media metadata
  width    Int?
  height   Int?
  fileSize Int?
  duration Int? // seconds (for video)

  // Tags stored as JSON array
  tags String[]

  // View tracking
  viewCount Int @default(0)

  // Audit fields
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  uploadedById String?

  @@index([active])
  @@index([featured])
  @@index([eventId])
  @@index([type, featured])
  @@index([featured, showOnHome])
  @@index([displayOrder])
  @@map("gallery_items")
}

// =============================================================================
// COMMITTEE & STAFF
// =============================================================================

/// Committee/Members (renamed from TrustMember)
model CommitteeMember {
  id String @id @default(uuid())

  name          String
  nameKn        String?
  designation   String
  designationKn String?

  bio   String? @db.Text
  bioKn String?

  // Media
  imageId String?
  image   Media?  @relation("CommitteeImages", fields: [imageId], references: [id])

  email String?
  phone String?

  type MemberType @default(MEMBER)

  order  Int     @default(0)
  active Boolean @default(true)

  isPontiff  Boolean @default(false)
  isResident Boolean @default(false)

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([type, active])
  @@map("committee_members")
}

enum MemberType {
  PONTIFF
  TRUSTEE
  MEMBER
  SECRETARY
  STAFF
  PRIEST
}

// =============================================================================
// FACILITIES & SERVICES
// =============================================================================

/// Temple Facilities
model Facility {
  id String @id @default(uuid())

  name          String
  nameKn        String?
  description   String?
  descriptionKn String?

  icon    String?
  imageId String?
  image   Media?  @relation(fields: [imageId], references: [id])
  color   String?

  instructions String?

  active Boolean @default(true)
  order  Int     @default(0)

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("facilities")
}

/// Amenities
model Amenity {
  id String @id @default(uuid())

  name        String
  description String?
  icon        String?

  available Boolean @default(true)
  order     Int     @default(0)

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("amenities")
}

// =============================================================================
// KNOWLEDGE BASE (Renamed from AI Knowledge)
// =============================================================================

/// Knowledge Categories
model KnowledgeCategory {
  id String @id @default(uuid())

  name        String
  description String?
  slug        String  @unique

  icon  String?
  color String?

  order  Int     @default(0)
  active Boolean @default(true)

  // Audit fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  articles KnowledgeArticle[]

  @@index([active])
  @@map("knowledge_categories")
}

/// Knowledge Articles
model KnowledgeArticle {
  id         String @id @default(uuid())
  categoryId String

  question   String
  questionKn String?

  answer   String  @db.Text
  answerKn String? @db.Text

  keywords String[] // For better search matching

  priority Int     @default(0)
  active   Boolean @default(true)

  // Media - Featured Image
  imageId String?
  image   Media?  @relation("ArticleImages", fields: [imageId], references: [id])

  viewCount       Int @default(0)
  helpfulCount    Int @default(0)
  notHelpfulCount Int @default(0)

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  category    KnowledgeCategory     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  attachments KnowledgeAttachment[]
  articleTags ArticleTag[]
  feedback    ChatFeedback[]

  @@index([active, priority])
  @@index([categoryId])
  @@map("knowledge_articles")
}

/// Knowledge Attachments (files associated with articles)
model KnowledgeAttachment {
  id        String @id @default(uuid())
  articleId String

  title       String
  description String?

  // Media - File
  mediaId String
  media   Media  @relation(fields: [mediaId], references: [id])

  fileSize Int? // bytes
  mimeType String?

  order  Int     @default(0)
  active Boolean @default(true)

  // Audit fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  article KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@map("knowledge_attachments")
}

/// Knowledge Tags
model KnowledgeTag {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  description String?

  // Audit fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  articleTags ArticleTag[]

  @@map("knowledge_tags")
}

/// Article-Tag junction table
model ArticleTag {
  id        String @id @default(uuid())
  articleId String
  tagId     String

  createdAt DateTime @default(now())

  article KnowledgeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     KnowledgeTag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([articleId, tagId])
  @@map("article_tags")
}

/// Chat Feedback (renamed from AIChatFeedback)
model ChatFeedback {
  id String @id @default(uuid())

  articleId String?
  userId    String?

  rating    Int // 1-5 stars
  isHelpful Boolean

  comment String? @db.Text

  userQuery  String? @db.Text
  aiResponse String? @db.Text

  createdAt DateTime @default(now())

  article KnowledgeArticle? @relation(fields: [articleId], references: [id])
  user    Profile?          @relation(fields: [userId], references: [id])

  @@map("chat_feedback")
}

// =============================================================================
// TESTIMONIALS
// =============================================================================

/// Devotee Testimonials
model Testimonial {
  id String @id @default(uuid())

  userId  String?  @unique
  profile Profile? @relation(fields: [userId], references: [id])

  name     String
  location String?

  title     String?
  content   String  @db.Text
  contentKn String? @db.Text

  rating Int? // 1-5 stars

  // Media
  imageId String?
  image   Media?  @relation(fields: [imageId], references: [id])

  approved  Boolean @default(false)
  featured  Boolean @default(false)
  published Boolean @default(false)

  approvedBy String?
  approvedAt DateTime?

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([approved, published])
  @@index([featured])
  @@map("testimonials")
}

// =============================================================================
// CONTACT & ENQUIRIES
// =============================================================================

/// Contact Enquiries
model ContactEnquiry {
  id String @id @default(uuid())

  name    String
  email   String
  phone   String?
  subject String?

  message  String          @db.Text
  category EnquiryCategory @default(GENERAL)

  status      EnquiryStatus @default(NEW)
  assignedTo  String?
  response    String?       @db.Text
  respondedAt DateTime?

  ipAddress String?
  userAgent String?

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status])
  @@index([category])
  @@map("contact_enquiries")
}

enum EnquiryCategory {
  GENERAL
  SEVA
  DONATION
  EVENT
  VISIT
  COMPLAINT
  FEEDBACK
}

enum EnquiryStatus {
  NEW
  IN_PROGRESS
  RESPONDED
  CLOSED
  SPAM
}

// =============================================================================
// UTILITY MODELS
// =============================================================================

/// Audit Log
model AuditLog {
  id String @id @default(uuid())

  userId     String?
  action     String
  entityType String?
  entityId   String?

  oldData Json?
  newData Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// =============================================================================
// DOCUMENTS
// =============================================================================

/// Document Category
model DocumentCategory {
  id String @id @default(uuid())

  name        String
  nameKn      String?
  description String?
  icon        String?

  order  Int     @default(0)
  active Boolean @default(true)

  // Audit fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents Document[]

  @@index([active, order])
  @@map("document_categories")
}

/// Document
model Document {
  id String @id @default(uuid())

  title       String
  titleKn     String?
  description String?

  categoryId String
  category   DocumentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // Media - File
  mediaId String
  media   Media  @relation(fields: [mediaId], references: [id])

  // File metadata (denormalized)
  fileName String?
  fileSize Int? // bytes
  mimeType String?

  featured Boolean @default(false)
  active   Boolean @default(true)
  order    Int     @default(0)

  downloadCount Int @default(0)

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([categoryId, active])
  @@index([featured])
  @@map("documents")
}

// =============================================================================
// GALLERY MODULE (Sprint 4.2)
// =============================================================================

/// Gallery Album Category
model GalleryCategory {
  id String @id @default(uuid())

  name        String  @unique
  nameKn      String?
  description String?
  slug        String  @unique

  icon  String?
  color String?

  order  Int     @default(0)
  active Boolean @default(true)

  // Festival year (optional, for time-based categories)
  year Int?

  // Audit fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  albums GalleryAlbum[]

  @@index([active, order])
  @@map("gallery_categories")
}

/// Gallery Album
model GalleryAlbum {
  id String @id @default(uuid())

  title       String
  titleKn     String?
  slug        String  @unique
  description String?
  descriptionKn String?

  // Cover image
  coverImageId String?
  coverImage   Media?  @relation("AlbumCoverImages", fields: [coverImageId], references: [id])

  // Category
  categoryId String?
  category   GalleryCategory? @relation(fields: [categoryId], references: [id])

  // Festival association (optional)
  festivalId String?
  festival   Event?  @relation("AlbumFestivals", fields: [festivalId], references: [id])

  // Visibility and status
  status     AlbumStatus @default(DRAFT)
  visibility AlbumVisibility @default(PRIVATE)

  // Features
  featured  Boolean @default(false)
  published Boolean @default(false)

  // Media counts (denormalized for performance)
  photoCount  Int @default(0)
  videoCount  Int @default(0)

  // Display
  displayOrder Int @default(0)

  // Metadata
  location  String?
  eventDate DateTime?

  // Audit fields
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  createdById String?
  updatedById String?

  // Relations
  items AlbumItem[]

  @@index([status, published])
  @@index([featured])
  @@index([categoryId])
  @@index([festivalId])
  @@index([eventDate])
  @@map("gallery_albums")
}

/// Album-Item junction (many-to-many)
model AlbumItem {
  id String @id @default(uuid())

  albumId String
  album   GalleryAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)

  itemId String
  item   GalleryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  // Display order within album
  displayOrder Int @default(0)

  // Audit
  createdAt DateTime @default(now())

  @@unique([albumId, itemId])
  @@index([albumId])
  @@index([itemId])
  @@map("album_items")
}

/// Gallery Tag
model GalleryTag {
  id   String @id @default(uuid())
  name String @unique
  slug String @unique

  // Audit fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("gallery_tags")
}

enum AlbumStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AlbumVisibility {
  PRIVATE
  PUBLIC
  UNLISTED
}

enum GalleryItemType {
  PHOTO
  VIDEO
}
