// =============================================================================
// Sri Raghavendra Swamy Temple - Database Schema
// Domain Model v5 - Approved Architecture
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// USER MANAGEMENT - RBAC (Profile + Role + UserRole)
// =============================================================================

/// User Profile - linked to Supabase Auth
model Profile {
  id            String    @id @default(uuid())
  userId        String    @unique
  email         String    @unique
  name          String?
  phone         String?
  address       String?
  avatarUrl     String?
  emailVerified Boolean   @default(false)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  donations     Donation[]
  bookings      Booking[]
  announcements Announcement[]
  testimonial   Testimonial?
  aiFeedback    AIChatFeedback[]
  userRoles     UserRole[]

  @@index([email])
  @@index([isActive])
  @@map("profiles")
}

/// Role definition
model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  permissions String[] // Array of permission strings

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userRoles UserRole[]

  @@map("roles")
}

/// User-Role association (many-to-many)
model UserRole {
  id        String @id @default(uuid())
  profileId String
  roleId    String

  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([profileId, roleId])
  @@map("user_roles")
}

// =============================================================================
// TEMPLE CONFIGURATION
// =============================================================================

/// Temple Information
model TempleInfo {
  id String @id @default(uuid())

  // Basic Info
  name        String
  shortName   String?
  tagline     String?
  description String?

  // Address
  address  String?
  city     String?
  district String?
  state    String?
  country  String  @default("India")
  pincode  String?

  // Contact
  phone          String?
  alternatePhone String?
  email          String?
  website        String?

  // Location
  mapEmbedUrl String?
  latitude    Float?
  longitude   Float?

  // Social Media
  socialFacebook  String?
  socialTwitter   String?
  socialInstagram String?
  socialYoutube   String?
  socialWhatsapp  String?

  // Bank Details for Donations
  bankName          String?
  bankAccountName   String?
  bankAccountNumber String?
  bankIFSCCode      String?
  bankUPIId         String?

  // Statistics
  establishedYear Int?
  priestCount     Int?
  dailyVisitors   Int?

  // Logo
  logoUrl    String?
  faviconUrl String?

  // Audit fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("temple_info")
}

/// Site-wide Settings (Key-Value Store)
model SiteSetting {
  id          String  @id @default(uuid())
  key         String  @unique
  value       String  @db.Text
  description String?
  category    String? // "general", "seo", "social", "email", etc.
  isPublic    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@map("site_settings")
}

// =============================================================================
// HOMEPAGE CONFIGURATION
// =============================================================================

/// Homepage Configuration
model HomepageConfig {
  id String @id @default(uuid())

  // Hero Section
  heroTitle               String?
  heroSubtitle            String?
  heroImageUrl            String?
  heroVideoUrl            String?
  heroPrimaryButtonText   String?
  heroPrimaryButtonUrl    String?
  heroSecondaryButtonText String?
  heroSecondaryButtonUrl  String?

  // About Section
  aboutTitle    String?
  aboutContent  String? @db.Text
  aboutImageUrl String?

  // Section Visibility
  showFeaturedEvents  Boolean @default(true)
  showFeaturedSevas   Boolean @default(true)
  showDonationSection Boolean @default(true)
  showGalleryPreview  Boolean @default(true)
  showAnnouncements   Boolean @default(true)
  showTestimonials    Boolean @default(true)
  showPanchanga       Boolean @default(true)

  // Limits
  featuredEventsLimit Int @default(6)
  featuredSevasLimit  Int @default(8)
  galleryPreviewLimit Int @default(8)
  testimonialLimit    Int @default(5)

  // Donation Section
  donationTitle    String?
  donationSubtitle String?

  // Announcement Banner
  announcementBannerText String?
  announcementBannerUrl  String?

  // Footer
  footerCopyright String?
  footerTagline   String?

  // Audit fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  media     Media?   @relation(fields: [mediaId], references: [id])
  mediaId   String?

  @@map("homepage_configs")
}

// =============================================================================
// TEMPLE SCHEDULE (TempleDay + TempleException)
// =============================================================================

/// Regular Temple Days
model TempleDay {
  id        String  @id @default(uuid())
  dayOfWeek Int // 0=Sunday, 1=Monday, etc.
  name      String? // e.g., "Sunday", "Monday"

  // Morning timings
  morningOpenTime  String? // e.g., "05:00"
  morningCloseTime String? // e.g., "13:00"

  // Evening timings
  eveningOpenTime  String?
  eveningCloseTime String?

  // Special notes
  notes String?

  // Status
  isHoliday Boolean @default(false)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dayOfWeek])
  @@map("temple_days")
}

/// Temple Schedule Exceptions (Special days, holidays, closures)
model TempleException {
  id String @id @default(uuid())

  date        DateTime
  name        String? // e.g., "Diwali", "Special Festival"
  description String?

  // Override timings (null means closed)
  morningOpenTime  String?
  morningCloseTime String?
  eveningOpenTime  String?
  eveningCloseTime String?

  // Status
  isClosed       Boolean @default(false)
  isSpecialEvent Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@map("temple_exceptions")
}

// =============================================================================
// CENTRALIZED MEDIA
// =============================================================================

/// Media Library (centralized media storage)
model Media {
  id String @id @default(uuid())

  // File Info
  filename     String
  originalName String?
  mimeType     String?
  fileSize     Int? // bytes

  // Storage
  bucket      String @default("media")
  storagePath String // Path in Supabase Storage

  // Metadata
  title       String?
  altText     String?
  caption     String?
  description String?

  // Classification
  type     MediaType @default(IMAGE)
  category String? // "events", "gallery", "poojas", "aaradhanes", etc.

  // Media-specific fields
  width    Int?
  height   Int?
  duration Int? // seconds (for audio/video)

  // Status
  isPublic   Boolean @default(true)
  isFeatured Boolean @default(false)
  isActive   Boolean @default(true)

  // Usage tracking
  viewCount     Int @default(0)
  downloadCount Int @default(0)

  // Upload info
  uploadedBy String?

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  eventImages       Event[]            @relation("EventImages")
  eventBanners      Event[]            @relation("EventBanners")
  galleryItems      GalleryItem[]
  aaradhaneImages   Aaradhane[]
  aaradhaneThumbs   Aaradhane[]        @relation("AaradhaneThumbnails")
  sevaimages        Seva[]             @relation("SevaImages")
  donationImages    DonationCampaign[]
  trustMemberImages TrustMember[]
  staffImages       Staff[]
  facilityImages    Facility[]
  testimonialImages Testimonial[]
  homepageImages    HomepageConfig[]

  @@index([type, isActive])
  @@index([category])
  @@index([isFeatured])
  @@map("media")
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

// =============================================================================
// ANNOUNCEMENTS
// =============================================================================

model Announcement {
  id      String  @id @default(uuid())
  title   String
  content String  @db.Text
  excerpt String?

  type     AnnouncementType @default(GENERAL)
  priority Priority         @default(NORMAL)

  isPinned  Boolean   @default(false)
  isActive  Boolean   @default(true)
  expiresAt DateTime?

  authorId String?
  author   Profile? @relation(fields: [authorId], references: [id])

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([isActive, expiresAt])
  @@index([type])
  @@index([priority])
  @@map("announcements")
}

enum AnnouncementType {
  GENERAL
  EVENT
  DONATION
  FESTIVAL
  MAINTENANCE
  URGENT
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// =============================================================================
// EVENTS & CALENDAR
// =============================================================================

/// Temple Events
model Event {
  id      String  @id @default(uuid())
  title   String
  titleKn String? // Kannada

  description   String? @db.Text
  descriptionKn String? @db.Text

  startDate DateTime
  endDate   DateTime
  startTime String?
  endTime   String?

  location   String?
  isOnline   Boolean @default(false)
  onlineLink String?

  type   EventType   @default(GENERAL)
  status EventStatus @default(UPCOMING)

  featured  Boolean @default(false)
  published Boolean @default(false)

  // Media
  imageId  String?
  image    Media?  @relation("EventImages", fields: [imageId], references: [id])
  bannerId String?
  banner   Media?  @relation("EventBanners", fields: [bannerId], references: [id])

  maxAttendees     Int?
  currentAttendees Int  @default(0)

  organizer    String?
  contactPhone String?
  contactEmail String?

  // Audit fields
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  // Relations
  bookings     BookingItem[]
  galleryItems GalleryItem[]

  @@index([startDate, published])
  @@index([status])
  @@map("events")
}

enum EventType {
  GENERAL
  FESTIVAL
  WORKSHOP
  SPIRITUAL
  CULTURAL
  MAINTENANCE
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

/// Festivals
model Festival {
  id     String  @id @default(uuid())
  name   String
  nameKn String?

  date    DateTime
  endDate DateTime?

  description   String? @db.Text
  descriptionKn String? @db.Text
  significance  String? @db.Text

  // Media
  imageUrl String?

  isMajorFestival Boolean @default(false)
  isHoliday       Boolean @default(true)

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([date])
  @@map("festivals")
}

/// Panchanga (Daily Calendar Data)
model Panchanga {
  id   String   @id @default(uuid())
  date DateTime @unique

  // Tithis
  tithi    String
  tithiEnd String?

  // Nakshatras
  nakshatra    String
  nakshatraEnd String?

  // Yoga
  yoga    String
  yogaEnd String?

  // Karana
  karana    String
  karanaEnd String?

  // Sun & Moon
  sunrise   String
  sunset    String
  moonrise  String?
  moonset   String?
  moonPhase String?

  // Auspicious Times
  brahmaMuhurta String?
  amritaKaalam  String?
  sunriseKaalam String?
  sunsetKaalam  String?

  // Rahukalam & Yamaganda
  rahukalam   String?
  yamaganda   String?
  durMuhurtam String?

  notes String?

  // Audit fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@map("panchangas")
}

/// Daily Pooja Schedule
model PoojaSchedule {
  id     String  @id @default(uuid())
  name   String
  nameKn String?

  time          String
  description   String?
  descriptionKn String?

  category  String? // "Morning", "Afternoon", "Evening", "Special"
  isSpecial Boolean @default(false)

  // Media
  imageUrl String?

  active Boolean @default(true)
  order  Int     @default(0)

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([active, order])
  @@map("pooja_schedules")
}

// =============================================================================
// UNIFIED BOOKING SYSTEM (Booking + BookingItem)
// =============================================================================

/// Unified Booking
model Booking {
  id String @id @default(uuid())

  // Booking Reference
  referenceNumber String @unique

  // User Info
  profileId String?
  profile   Profile? @relation(fields: [profileId], references: [id])

  // Guest Info (for non-logged in users)
  guestName  String?
  guestEmail String?
  guestPhone String?

  // Booking Details
  bookingType   BookingType
  bookingDate   DateTime
  preferredTime String?

  // Status
  status BookingStatus @default(PENDING)

  // Financial
  totalAmount Float  @default(0)
  currency    String @default("INR")
  paidAmount  Float  @default(0)

  // Devotee Info (for religious bookings)
  devoteeName String?
  gothra      String?
  nakshatra   String?
  gotraKn     String?

  // Notes
  notes      String? @db.Text
  adminNotes String? @db.Text

  // Receipt
  receiptNumber String?
  receiptUrl    String?

  // Audit fields
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  // Relations
  items BookingItem[]

  @@index([profileId])
  @@index([bookingType, bookingDate])
  @@index([status])
  @@map("bookings")
}

enum BookingType {
  SEVA
  EVENT
  DONATION
  OTHER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  REFUNDED
}

/// Booking Items (supports multiple items per booking)
model BookingItem {
  id        String @id @default(uuid())
  bookingId String

  // Reference to the booked entity
  itemType BookingItemType
  itemId   String // ID of Seva, Event, etc.

  // Item Details (denormalized for historical record)
  itemName   String
  itemNameKn String?

  // Quantity and Price
  quantity   Int   @default(1)
  unitPrice  Float @default(0)
  totalPrice Float @default(0)

  // Date/Time
  requestedDate DateTime?
  requestedTime String?

  // Status
  status BookingStatus @default(CONFIRMED)

  // Additional Info
  notes String? @db.Text

  // Audit fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  event   Event?  @relation(fields: [eventId], references: [id])
  eventId String?

  @@index([bookingId])
  @@index([itemType, itemId])
  @@map("booking_items")
}

enum BookingItemType {
  SEVA
  SEVA_BOOKING
  EVENT
  EVENT_BOOKING
  DONATION
  OTHER
}

// =============================================================================
// SEVAS (SERVICES)
// =============================================================================

/// Seva Types
model Seva {
  id String @id @default(uuid())

  name          String
  nameKn        String?
  description   String? @db.Text
  descriptionKn String? @db.Text

  price    Float  @default(0)
  currency String @default("INR")

  duration String? // e.g., "30 minutes", "1 hour"

  category String? // "Daily", "Special", "Premium"

  // Media
  imageId  String?
  image    Media?  @relation("SevaImages", fields: [imageId], references: [id])
  iconName String?

  active   Boolean @default(true)
  featured Boolean @default(false)

  maxPerDay         Int? // Maximum bookings per day
  minAdvanceBooking Int? // Minimum days in advance
  maxAdvanceBooking Int? // Maximum days in advance

  instructions String? @db.Text
  benefits     String? @db.Text

  order Int @default(0)

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  aaradhaneSevas AaradhaneSeva[]

  @@index([active, featured])
  @@index([category])
  @@map("sevas")
}

// =============================================================================
// AARADHANE (SPECIAL POOJAS)
// =============================================================================

/// Aaradhane (Special Poojas/Deities)
model Aaradhane {
  id String @id @default(uuid())

  title   String
  titleKn String?

  deityName String?
  guruName  String?

  description  String? @db.Text
  significance String? @db.Text

  startDate DateTime?
  endDate   DateTime?

  // Media
  imageId     String?
  image       Media?  @relation(fields: [imageId], references: [id])
  thumbnailId String?
  thumbnail   Media?  @relation("AaradhaneThumbnails", fields: [thumbnailId], references: [id])

  rituals   String[] // Array of ritual names
  offerings String[] // Array of offerings

  featured Boolean @default(false)
  active   Boolean @default(true)
  order    Int     @default(0)

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  sevas AaradhaneSeva[]

  @@index([featured, active])
  @@map("aaradhanes")
}

/// Aaradhane Seva (Associated Sevas)
model AaradhaneSeva {
  id          String @id @default(uuid())
  aaradhaneId String

  name        String
  nameKn      String?
  description String? @db.Text

  amount   Float  @default(0)
  currency String @default("INR")

  active Boolean @default(true)
  order  Int     @default(0)

  // Audit fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  aaradhane Aaradhane @relation(fields: [aaradhaneId], references: [id], onDelete: Cascade)
  seva      Seva?     @relation(fields: [sevaId], references: [id])
  sevaId    String?

  @@index([aaradhaneId])
  @@map("aaradhane_sevas")
}

// =============================================================================
// DONATIONS
// =============================================================================

/// Donation Campaigns
model DonationCampaign {
  id String @id @default(uuid())

  title         String
  titleKn       String?
  description   String? @db.Text
  descriptionKn String? @db.Text

  targetAmount Float?
  raisedAmount Float  @default(0)
  currency     String @default("INR")

  // Media
  imageId  String?
  image    Media?  @relation(fields: [imageId], references: [id])
  videoUrl String?

  active   Boolean @default(true)
  featured Boolean @default(false)

  startDate DateTime?
  endDate   DateTime?

  urgencyLevel UrgencyLevel @default(NORMAL)

  category String? // "Development", "Maintenance", "Charity", "Temple Fund"

  createdBy String?

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  donations Donation[]

  @@index([active, featured])
  @@map("donation_campaigns")
}

enum UrgencyLevel {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

/// Donations
model Donation {
  id String @id @default(uuid())

  // User
  profileId String?
  profile   Profile? @relation(fields: [profileId], references: [id])

  // Campaign
  campaignId String?
  campaign   DonationCampaign? @relation(fields: [campaignId], references: [id])

  // Amount
  amount   Float
  currency String @default("INR")

  // Payment
  paymentMethod PaymentMethod?
  paymentId     String?
  transactionId String?
  status        DonationStatus @default(PENDING)

  // Donor Info
  donorName    String
  donorEmail   String
  donorPhone   String?
  donorAddress String?
  anonymous    Boolean @default(false)

  message    String?
  dedication String?

  // Receipt
  receiptNumber String?
  receiptUrl    String?

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  payments DonationPayment[]

  @@index([profileId])
  @@index([campaignId])
  @@index([status, createdAt])
  @@map("donations")
}

enum PaymentMethod {
  CARD
  UPI
  NET_BANKING
  WALLET
  BANK_TRANSFER
  CASH
  CHEQUE
}

enum DonationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

/// Donation Payment Attempts
model DonationPayment {
  id         String @id @default(uuid())
  donationId String

  amount   Float
  currency String @default("INR")

  paymentMethod PaymentMethod
  paymentId     String?
  transactionId String?

  status PaymentAttemptStatus @default(PENDING)

  responseData Json?
  errorMessage String?

  attemptedAt DateTime  @default(now())
  completedAt DateTime?

  donation Donation @relation(fields: [donationId], references: [id], onDelete: Cascade)

  @@index([donationId])
  @@map("donation_payments")
}

enum PaymentAttemptStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  REFUNDED
}

// =============================================================================
// GALLERY
// =============================================================================

/// Gallery Items
model GalleryItem {
  id String @id @default(uuid())

  title         String?
  titleKn       String?
  description   String?
  descriptionKn String?

  // Media
  mediaId String
  media   Media  @relation(fields: [mediaId], references: [id])

  // Event association
  eventId String?
  event   Event?  @relation(fields: [eventId], references: [id])

  featured Boolean @default(false)
  active   Boolean @default(true)
  order    Int     @default(0)

  uploadedBy String?

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([active])
  @@index([featured])
  @@index([eventId])
  @@map("gallery_items")
}

// =============================================================================
// COMMITTEE & STAFF
// =============================================================================

/// Trust/Committee Members
model TrustMember {
  id String @id @default(uuid())

  name          String
  nameKn        String?
  designation   String
  designationKn String?

  bio   String? @db.Text
  bioKn String?

  // Media
  imageId String?
  image   Media?  @relation(fields: [imageId], references: [id])

  email String?
  phone String?

  type MemberType @default(MEMBER)

  order  Int     @default(0)
  active Boolean @default(true)

  isPontiff  Boolean @default(false)
  isResident Boolean @default(false)

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([type, active])
  @@map("trust_members")
}

enum MemberType {
  PONTIFF
  TRUSTEE
  MEMBER
  SECRETARY
  STAFF
  PRIEST
}

/// Temple Staff
model Staff {
  id String @id @default(uuid())

  name        String
  designation String
  department  String?

  // Media
  imageId String?
  image   Media?  @relation(fields: [imageId], references: [id])

  bio String? @db.Text

  phone String?
  email String?

  active Boolean @default(true)
  order  Int     @default(0)

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("staff")
}

// =============================================================================
// FACILITIES & SERVICES
// =============================================================================

/// Temple Facilities
model Facility {
  id String @id @default(uuid())

  name          String
  nameKn        String?
  description   String?
  descriptionKn String?

  icon    String?
  imageId String?
  image   Media?  @relation(fields: [imageId], references: [id])
  color   String?

  instructions String?

  active Boolean @default(true)
  order  Int     @default(0)

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("facilities")
}

/// Amenities
model Amenity {
  id String @id @default(uuid())

  name        String
  description String?
  icon        String?

  available Boolean @default(true)
  order     Int     @default(0)

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("amenities")
}

/// Future Plans
model FuturePlan {
  id String @id @default(uuid())

  title         String
  titleKn       String?
  description   String? @db.Text
  descriptionKn String? @db.Text

  icon     String?
  imageUrl String?

  targetAmount Float?
  raisedAmount Float  @default(0)

  status   PlanStatus @default(PLANNING)
  priority Int        @default(0)

  active   Boolean @default(true)
  featured Boolean @default(false)
  order    Int     @default(0)

  startDate     DateTime?
  targetDate    DateTime?
  completedDate DateTime?

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("future_plans")
}

enum PlanStatus {
  PLANNING
  APPROVED
  IN_PROGRESS
  COMPLETED
  ON_HOLD
}

// =============================================================================
// AI KNOWLEDGE BASE
// =============================================================================

/// AI Chatbot Knowledge Categories
model AIKnowledgeCategory {
  id String @id @default(uuid())

  name        String
  description String?

  icon  String?
  color String?

  order  Int     @default(0)
  active Boolean @default(true)

  // Audit fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  articles AIKnowledgeArticle[]

  @@map("ai_knowledge_categories")
}

/// AI Chatbot Knowledge Articles
model AIKnowledgeArticle {
  id         String @id @default(uuid())
  categoryId String

  question   String
  questionKn String?

  answer   String  @db.Text
  answerKn String? @db.Text

  keywords String[] // For better search matching

  priority Int     @default(0)
  active   Boolean @default(true)

  viewCount       Int @default(0)
  helpfulCount    Int @default(0)
  notHelpfulCount Int @default(0)

  // Audit fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category AIKnowledgeCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  feedback AIChatFeedback[]

  @@index([active, priority])
  @@map("ai_knowledge_articles")
}

/// AI Chat Feedback
model AIChatFeedback {
  id String @id @default(uuid())

  articleId String?
  userId    String?

  rating    Int // 1-5 stars
  isHelpful Boolean

  comment String? @db.Text

  userQuery  String? @db.Text
  aiResponse String? @db.Text

  createdAt DateTime @default(now())

  article AIKnowledgeArticle? @relation(fields: [articleId], references: [id])
  user    Profile?            @relation(fields: [userId], references: [id])

  @@map("ai_chat_feedback")
}

// =============================================================================
// TESTIMONIALS
// =============================================================================

/// Devotee Testimonials
model Testimonial {
  id String @id @default(uuid())

  userId  String?  @unique
  profile Profile? @relation(fields: [userId], references: [id])

  name     String
  location String?

  title     String?
  content   String  @db.Text
  contentKn String? @db.Text

  rating Int? // 1-5 stars

  // Media
  imageId String?
  image   Media?  @relation(fields: [imageId], references: [id])

  approved  Boolean @default(false)
  featured  Boolean @default(false)
  published Boolean @default(false)

  approvedBy String?
  approvedAt DateTime?

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([approved, published])
  @@map("testimonials")
}

// =============================================================================
// CONTACT & ENQUIRIES
// =============================================================================

/// Contact Enquiries
model ContactEnquiry {
  id String @id @default(uuid())

  name    String
  email   String
  phone   String?
  subject String?

  message  String          @db.Text
  category EnquiryCategory @default(GENERAL)

  status      EnquiryStatus @default(NEW)
  assignedTo  String?
  response    String?       @db.Text
  respondedAt DateTime?

  ipAddress String?
  userAgent String?

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status])
  @@map("contact_enquiries")
}

enum EnquiryCategory {
  GENERAL
  SEVA
  DONATION
  EVENT
  VISIT
  COMPLAINT
  FEEDBACK
}

enum EnquiryStatus {
  NEW
  IN_PROGRESS
  RESPONDED
  CLOSED
  SPAM
}

// =============================================================================
// UTILITY MODELS
// =============================================================================

/// Email Logs
model EmailLog {
  id String @id @default(uuid())

  to      String
  subject String
  body    String @db.Text

  status       EmailStatus @default(PENDING)
  sentAt       DateTime?
  failedAt     DateTime?
  errorMessage String?

  templateId   String?
  templateData Json?

  createdAt DateTime @default(now())

  @@index([to, createdAt])
  @@map("email_logs")
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
  BOUNCED
}

/// Audit Log
model AuditLog {
  id String @id @default(uuid())

  userId     String?
  action     String
  entityType String?
  entityId   String?

  oldData Json?
  newData Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// =============================================================================
// DOCUMENTS
// =============================================================================

/// Document Category
model DocumentCategory {
  id String @id @default(uuid())

  name        String
  nameKn      String?
  description String?
  icon        String?

  order  Int     @default(0)
  active Boolean @default(true)

  // Audit fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents Document[]

  @@index([active, order])
  @@map("document_categories")
}

/// Document
model Document {
  id String @id @default(uuid())

  title       String
  titleKn     String?
  description String?

  categoryId String
  category   DocumentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  fileUrl  String
  fileName String?
  fileSize Int? // bytes
  mimeType String?

  featured Boolean @default(false)
  active   Boolean @default(true)
  order    Int     @default(0)

  downloadCount Int @default(0)

  // Audit fields
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([categoryId, active])
  @@index([featured])
  @@map("documents")
}
