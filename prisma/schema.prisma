// =============================================================================
// Sri Raghavendra Swamy Temple - Database Schema
// Sprint 2 - Database Design
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// USER MANAGEMENT
// =============================================================================

/// User Profile - linked to Supabase Auth
model Profile {
  id            String    @id @default(cuid())
  userId        String    @unique
  email         String    @unique
  name          String?
  role          UserRole  @default(DEVOTEE)
  phone         String?
  address       String?
  avatarUrl     String?
  emailVerified Boolean   @default(false)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  donations       Donation[]
  sevaBookings    SevaBooking[]
  announcements   Announcement[]
  testimonial     Testimonial?
  aiFeedback      AIChatFeedback[]

  @@index([email])
  @@index([role])
  @@map("profiles")
}

/// User Roles
enum UserRole {
  DEVOTEE      // Regular user/devotee
  VOLUNTEER    // Temple volunteer
  PRIEST       // Temple priest
  STAFF        // Temple staff
  ADMIN        // Temple administrator
  SUPER_ADMIN  // Super administrator
}

/// User Sessions - for tracking active sessions
model UserSession {
  id           String   @id @default(cuid())
  profileId    String
  sessionToken String   @unique
  deviceInfo   String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([expiresAt])
  @@map("user_sessions")
}

// =============================================================================
// TEMPLE SETTINGS
// =============================================================================

/// Temple Information
model TempleSettings {
  id              String  @id @default(cuid())
  templeName      String
  shortName       String?
  tagline         String?
  description     String?
  address         String?
  city            String?
  district        String?
  state           String?
  country         String  @default("India")
  pincode         String?
  phone           String?
  alternatePhone  String?
  email           String?
  website         String?
  mapEmbedUrl     String?
  latitude        Float?
  longitude       Float?

  // Social Media
  socialFacebook    String?
  socialTwitter     String?
  socialInstagram   String?
  socialYoutube     String?
  socialWhatsapp    String?

  // Bank Details for Donations
  bankName         String?
  bankAccountName  String?
  bankAccountNumber String?
  bankIFSCCode     String?
  bankUPIId        String?

  // Statistics
  establishedYear   Int?
  priestCount      Int?
  dailyVisitors    Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("temple_settings")
}

/// Homepage Configuration
model HomepageSettings {
  id               String  @id @default(cuid())
  heroTitle        String?
  heroSubtitle     String?
  heroImageUrl     String?
  heroVideoUrl     String?

  aboutTitle       String?
  aboutContent     String?
  aboutImageUrl    String?

  showFeaturedEvents  Boolean @default(true)
  showFeaturedSevas   Boolean @default(true)
  showDonationSection Boolean @default(true)
  showGalleryPreview   Boolean @default(true)
  showAnnouncements    Boolean @default(true)

  featuredEventsLimit  Int @default(6)
  featuredSevasLimit    Int @default(8)
  galleryPreviewLimit   Int @default(8)

  donationTitle     String?
  donationSubtitle  String?
  newsTitle         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("homepage_settings")
}

/// Temple Timings
model TempleTiming {
  id         String   @id @default(cuid())
  dayOfWeek  Int      // 0=Sunday, 1=Monday, etc.
  openTime   String   // e.g., "05:00"
  closeTime  String   // e.g., "21:00"
  isHoliday  Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([dayOfWeek])
  @@map("temple_timings")
}

// =============================================================================
// ANNOUNCEMENTS
// =============================================================================

/// Temple Announcements
model Announcement {
  id          String           @id @default(cuid())
  title       String
  content     String
  excerpt     String?

  type        AnnouncementType @default(GENERAL)
  priority    Priority         @default(NORMAL)

  isPinned    Boolean          @default(false)
  active      Boolean          @default(true)
  expiresAt   DateTime?

  authorId    String?
  author      Profile?         @relation(fields: [authorId], references: [id])

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([active, expiresAt])
  @@index([type])
  @@map("announcements")
}

enum AnnouncementType {
  GENERAL
  EVENT
  DONATION
  FESTIVAL
  MAINTENANCE
  URGENT
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// =============================================================================
// EVENTS & CALENDAR
// =============================================================================

/// Temple Events
model Event {
  id          String      @id @default(cuid())
  title       String
  titleKannada String?
  description String?
  descriptionKannada String?

  startDate   DateTime
  endDate     DateTime
  startTime   String?
  endTime     String?

  location    String?
  isOnline    Boolean     @default(false)
  onlineLink  String?

  type        EventType   @default(GENERAL)
  status      EventStatus @default(UPCOMING)

  featured    Boolean     @default(false)
  published   Boolean     @default(false)

  imageUrl    String?
  bannerUrl   String?

  maxAttendees Int?
  currentAttendees Int @default(0)

  organizer   String?
  contactPhone String?
  contactEmail String?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  bookings    EventBooking[]

  @@index([startDate, published])
  @@index([status])
  @@map("events")
}

enum EventType {
  GENERAL
  FESTIVAL
  WORKSHOP
  SPIRITUAL
  CULTURAL
  MAINTENANCE
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

/// Event Bookings
model EventBooking {
  id           String          @id @default(cuid())
  eventId      String
  userId       String?
  attendeeName String
  attendeeEmail String
  attendeePhone String?
  tickets      Int             @default(1)
  status       BookingStatus   @default(CONFIRMED)
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  event        Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_bookings")
}

/// Festivals
model Festival {
  id              String   @id @default(cuid())
  name            String
  nameKannada     String?
  date            DateTime
  endDate         DateTime?
  description     String?
  descriptionKannada String?
  significance    String?

  imageUrl        String?
  isMajorFestival Boolean @default(false)
  isHoliday       Boolean @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([date])
  @@map("festivals")
}

/// Panchanga (Daily Calendar Data)
model Panchanga {
  id          String   @id @default(cuid())
  date        DateTime @unique

  // Tithis
  tithi       String
  tithiEnd    String?

  // Nakshatras
  nakshatra   String
  nakshatraEnd String?

  // Yoga
  yoga        String
  yogaEnd     String?

  // Karana
  karana      String
  karanaEnd   String?

  // Sun & Moon
  sunrise     String
  sunset      String
  moonrise    String?
  moonset     String?
  moonPhase   String?

  // Auspicious Times
  brahmaMuhurta String?
  amritaKaalam  String?
  sunriseKaalam String?
  sunsetKaalam  String?

  // Rahukalam & Yamaganda
  rahukalam   String?
  yamaganda   String?
  durMuhurtam String?

  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@map("panchangas")
}

/// Daily Pooja Schedule
model PoojaSchedule {
  id          String   @id @default(cuid())
  name        String
  nameKannada String?
  time        String
  description String?
  descriptionKannada String?

  category    String?  // "Morning", "Afternoon", "Evening", "Special"
  isSpecial   Boolean @default(false)

  active      Boolean  @default(true)
  order       Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active, order])
  @@map("pooja_schedules")
}

// =============================================================================
// SEVAS (SERVICES)
// =============================================================================

/// Seva Types
model Seva {
  id                  String   @id @default(cuid())
  name                String
  nameKannada         String?
  description         String?
  descriptionKannada  String?

  price               Float    @default(0)
  priceKannada         Float?
  currency            String   @default("INR")

  duration            String?  // e.g., "30 minutes", "1 hour"
  category            String?  // "Daily", "Special", "Premium"

  imageUrl            String?
  iconName            String?

  active              Boolean  @default(true)
  featured             Boolean @default(false)

  maxPerDay           Int?     // Maximum bookings per day
  minAdvanceBooking    Int?     // Minimum days in advance
  maxAdvanceBooking    Int?     // Maximum days in advance

  instructions        String?  // Special instructions for devotees
  benefits            String?  // Spiritual benefits

  order               Int      @default(0)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  bookings            SevaBooking[]

  @@index([active, featured])
  @@index([category])
  @@map("sevas")
}

/// Seva Bookings
model SevaBooking {
  id           String        @id @default(cuid())
  userId       String
  sevaId       String
  bookingDate  DateTime
  preferredTime String?

  status       BookingStatus @default(PENDING)
  notes        String?

  amount       Float
  currency     String        @default("INR")
  paymentId    String?
  paymentStatus PaymentStatus @default(PENDING)

  devoteeName  String?
  gothra       String?
  nakshatra    String?

  // Receipt info
  receiptNumber String?
  receiptUrl   String?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  profile      Profile       @relation(fields: [userId], references: [id])
  seva         Seva          @relation(fields: [sevaId], references: [id])

  @@index([userId, bookingDate])
  @@index([sevaId, bookingDate])
  @@index([status])
  @@map("seva_bookings")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// =============================================================================
// DONATIONS
// =============================================================================

/// Donation Campaigns
model DonationCampaign {
  id              String   @id @default(cuid())
  title           String
  titleKannada    String?
  description     String?
  descriptionKannada String?

  targetAmount    Float?
  raisedAmount    Float    @default(0)
  currency        String   @default("INR")

  imageUrl        String?
  videoUrl       String?

  active          Boolean  @default(true)
  featured        Boolean  @default(false)

  startDate       DateTime?
  endDate         DateTime?

  urgencyLevel    UrgencyLevel @default(NORMAL)

  category        String?  // "Development", "Maintenance", "Charity", "Temple Fund"

  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  donations       Donation[]

  @@index([active, featured])
  @@map("donation_campaigns")
}

enum UrgencyLevel {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

/// Donations
model Donation {
  id             String           @id @default(cuid())
  userId         String?
  campaignId     String?

  amount         Float
  currency       String           @default("INR")

  paymentMethod  PaymentMethod?
  paymentId      String?
  transactionId  String?

  status         DonationStatus   @default(PENDING)

  // Donor Information
  donorName      String
  donorEmail     String
  donorPhone     String?
  anonymous      Boolean         @default(false)

  message        String?
  dedication      String?

  receiptNumber  String?
  receiptUrl     String?

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  profile        Profile?        @relation(fields: [userId], references: [id])
  campaign       DonationCampaign? @relation(fields: [campaignId], references: [id])

  @@index([userId])
  @@index([campaignId])
  @@index([status, createdAt])
  @@map("donations")
}

enum PaymentMethod {
  CARD
  UPI
  NET_BANKING
  WALLET
  BANK_TRANSFER
  CASH
  CHEQUE
}

enum DonationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

// =============================================================================
// GALLERY
// =============================================================================

/// Gallery Images & Videos
model GalleryItem {
  id           String    @id @default(cuid())
  title        String?
  titleKannada String?
  description  String?
  descriptionKannada String?

  src          String    // Storage URL or local path
  thumbnailUrl String?

  type         MediaType @default(IMAGE)
  category     String?   // "Temple", "Events", "Festivals", "Construction", "Staff"

  featured     Boolean   @default(false)
  active       Boolean   @default(true)
  order        Int       @default(0)

  // For videos
  videoDuration Int?
  videoUrl     String?

  // Metadata
  altText      String?
  credit       String?

  // Event association
  eventId      String?
  event        Event?    @relation(fields: [eventId], references: [id])

  uploadedBy   String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([type, active])
  @@index([category, active])
  @@map("gallery_items")
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

// =============================================================================
// COMMITTEE & STAFF
// =============================================================================

/// Trust/Committee Members
model TrustMember {
  id              String   @id @default(cuid())
  name            String
  nameKannada     String?
  designation     String
  designationKannada String?

  bio             String?
  bioKannada      String?

  imageUrl        String?

  email           String?
  phone           String?

  type            MemberType @default(MEMBER)

  order           Int      @default(0)
  active          Boolean  @default(true)

  isPontiff       Boolean  @default(false)
  isResident      Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([type, active])
  @@map("trust_members")
}

enum MemberType {
  PONTIFF
 _TRUSTEE
  MEMBER
  SECRETARY
  STAFF
  PRIEST
}

/// Temple Staff
model Staff {
  id          String   @id @default(cuid())
  name        String
  designation String
  department  String?

  imageUrl    String?
  bio         String?

  phone       String?
  email       String?

  active      Boolean  @default(true)
  order       Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("staff")
}

// =============================================================================
// FACILITIES & SERVICES
// =============================================================================

/// Temple Facilities
model Facility {
  id          String   @id @default(cuid())
  name        String
  nameKannada String?
  description String?
  descriptionKannada String?

  icon        String?
  imageUrl    String?
  color       String?

  instructions String?

  isActive    Boolean  @default(true)
  order       Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("facilities")
}

/// Amenities
model Amenity {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String?

  isAvailable Boolean  @default(true)
  order       Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("amenities")
}

// =============================================================================
// FUTURE PLANS & DEVELOPMENTS
// =============================================================================

/// Future Plans
model FuturePlan {
  id              String   @id @default(cuid())
  title           String
  titleKannada    String?
  description     String?
  descriptionKannada String?

  icon            String?
  imageUrl        String?

  targetAmount    Float?
  raisedAmount    Float    @default(0)

  status          PlanStatus @default(PLANNING)
  priority        Int      @default(0)

  isActive        Boolean  @default(true)
  isFeatured      Boolean  @default(false)
  order           Int      @default(0)

  startDate       DateTime?
  targetDate      DateTime?
  completedDate   DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("future_plans")
}

enum PlanStatus {
  PLANNING
  APPROVED
  IN_PROGRESS
  COMPLETED
  ON_HOLD
}

// =============================================================================
// AI KNOWLEDGE BASE
// =============================================================================

/// AI Chatbot Knowledge Categories
model AIKnowledgeCategory {
  id          String   @id @default(cuid())
  name        String
  description String?

  icon        String?
  color       String?

  order       Int      @default(0)
  active      Boolean  @default(true)

  articles    AIKnowledgeArticle[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ai_knowledge_categories")
}

/// AI Chatbot Knowledge Articles
model AIKnowledgeArticle {
  id          String   @id @default(cuid())
  categoryId  String

  question    String
  questionKannada String?

  answer      String   @db.Text
  answerKannada String? @db.Text

  keywords    String[] // For better search matching

  priority    Int      @default(0)
  active      Boolean  @default(true)

  viewCount   Int      @default(0)
  helpfulCount Int     @default(0)
  notHelpfulCount Int  @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category    AIKnowledgeCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  feedback    AIChatFeedback[]

  @@index([active, priority])
  @@map("ai_knowledge_articles")
}

/// AI Chat Feedback
model AIChatFeedback {
  id          String   @id @default(cuid())
  articleId   String?
  userId      String?

  rating      Int      // 1-5 stars
  isHelpful   Boolean

  comment     String?  @db.Text

  userQuery   String?  @db.Text
  aiResponse  String?  @db.Text

  createdAt   DateTime @default(now())

  article     AIKnowledgeArticle? @relation(fields: [articleId], references: [id])
  user        Profile? @relation(fields: [userId], references: [id])

  @@map("ai_chat_feedback")
}

// =============================================================================
// TESTIMONIALS
// =============================================================================

/// Devotee Testimonials
model Testimonial {
  id          String   @id @default(cuid())
  userId      String?  @unique
  profile     Profile? @relation(fields: [userId], references: [id])

  name        String
  location    String?

  title       String?
  content     String   @db.Text
  contentKannada String? @db.Text

  rating      Int?     // 1-5 stars

  imageUrl    String?

  isApproved  Boolean  @default(false)
  isFeatured  Boolean  @default(false)
  isPublished Boolean  @default(false)

  approvedBy  String?
  approvedAt  DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isApproved, isPublished])
  @@map("testimonials")
}

// =============================================================================
// CONTACT & ENQUIRIES
// =============================================================================

/// Contact Enquiries
model ContactEnquiry {
  id          String       @id @default(cuid())
  name        String
  email       String
  phone       String?
  subject     String?

  message     String       @db.Text
  category    EnquiryCategory @default(GENERAL)

  status      EnquiryStatus @default(NEW)
  assignedTo  String?
  response    String?      @db.Text
  respondedAt DateTime?

  ipAddress   String?
  userAgent   String?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@map("contact_enquiries")
}

enum EnquiryCategory {
  GENERAL
  SEVA
  DONATION
  EVENT
  VISIT
  COMPLAINT
  FEEDBACK
}

enum EnquiryStatus {
  NEW
  IN_PROGRESS
  RESPONDED
  CLOSED
  SPAM
}

// =============================================================================
// UTILITY MODELS
// =============================================================================

/// Email Logs
model EmailLog {
  id          String   @id @default(cuid())
  to          String
  subject     String
  body        String   @db.Text

  status      EmailStatus @default(PENDING)
  sentAt      DateTime?
  failedAt    DateTime?
  errorMessage String?

  templateId  String?
  templateData Json?

  createdAt   DateTime @default(now())

  @@index([to, createdAt])
  @@map("email_logs")
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
  BOUNCED
}

/// Audit Log
model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entityType  String?
  entityId    String?

  oldData     Json?
  newData     Json?

  ipAddress   String?
  userAgent   String?

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
