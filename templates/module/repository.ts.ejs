/**
 * ${MODULE_NAME} Repository - Database access layer
 * 
 * This file provides direct Prisma database operations for ${MODULE_NAME}.
 * All data access should go through this layer.
 */

import { prisma } from "@/lib/db";
import { logger } from "@/lib/logger";
import { handlePrismaError } from "@/lib/errors";
import type { Prisma } from "@prisma/client";

// =============================================================================
// TYPES
// =============================================================================

export interface ${ModuleName} {
  id: string;
  name: string;
  // ... add your fields
  createdAt: Date;
  updatedAt: Date;
  deletedAt?: Date | null;
}

export interface ${ModuleName}Request {
  name: string;
  // ... add your fields
}

export interface ${ModuleName}Query {
  // ... add your query parameters
}

// =============================================================================
// TRANSFORMERS
// =============================================================================

function transform${ModuleName}(prisma${ModuleName}: any): ${ModuleName} {
  return {
    id: prisma${ModuleName}.id,
    name: prisma${ModuleName}.name,
    // ... add your transformations
    createdAt: prisma${ModuleName}.createdAt,
    updatedAt: prisma${ModuleName}.updatedAt,
    deletedAt: prisma${ModuleName}.deletedAt,
  };
}

// =============================================================================
// CRUD OPERATIONS
// =============================================================================

export const ${moduleName}Repository = {
  /**
   * Get all records with optional filtering
   */
  async findMany(query?: ${ModuleName}Query): Promise<${ModuleName}[]> {
    try {
      const where: Prisma.${ModuleName}WhereInput = {
        deletedAt: null,
      };

      // Add your filters here

      const records = await prisma.${moduleName}.findMany({
        where,
        // include: { ... },
        orderBy: { createdAt: "desc" },
        take: 100,
      });

      return records.map(transform${ModuleName});
    } catch (error) {
      logger.error("[${ModuleName}Repository] findMany failed", error);
      throw handlePrismaError(error);
    }
  },

  /**
   * Get a single record by ID
   */
  async findById(id: string): Promise<${ModuleName} | null> {
    try {
      const record = await prisma.${moduleName}.findUnique({
        where: { id },
      });

      if (!record || record.deletedAt) {
        return null;
      }

      return transform${ModuleName}(record);
    } catch (error) {
      logger.error("[${ModuleName}Repository] findById failed", error);
      throw handlePrismaError(error);
    }
  },

  /**
   * Create a new record
   */
  async create(data: ${ModuleName}Request): Promise<${ModuleName}> {
    try {
      const record = await prisma.${moduleName}.create({
        data: {
          name: data.name,
          // ... add your fields
        },
      });

      logger.info("[${ModuleName}Repository] Created record", { id: record.id });
      return transform${ModuleName}(record);
    } catch (error) {
      logger.error("[${ModuleName}Repository] create failed", error);
      throw handlePrismaError(error);
    }
  },

  /**
   * Update an existing record
   */
  async update(id: string, data: Partial<${ModuleName}Request>): Promise<${ModuleName}> {
    try {
      const updateData: Prisma.${ModuleName}UpdateInput = {};

      // Add your update fields here
      // if (data.name !== undefined) updateData.name = data.name;

      const record = await prisma.${moduleName}.update({
        where: { id },
        data: updateData,
      });

      logger.info("[${ModuleName}Repository] Updated record", { id });
      return transform${ModuleName}(record);
    } catch (error) {
      logger.error("[${ModuleName}Repository] update failed", error);
      throw handlePrismaError(error);
    }
  },

  /**
   * Soft delete a record
   */
  async delete(id: string): Promise<void> {
    try {
      await prisma.${moduleName}.update({
        where: { id },
        data: { deletedAt: new Date() },
      });

      logger.info("[${ModuleName}Repository] Soft deleted record", { id });
    } catch (error) {
      logger.error("[${ModuleName}Repository] delete failed", error);
      throw handlePrismaError(error);
    }
  },

  /**
   * Hard delete a record (use with caution)
   */
  async hardDelete(id: string): Promise<void> {
    try {
      await prisma.${moduleName}.delete({
        where: { id },
      });

      logger.info("[${ModuleName}Repository] Hard deleted record", { id });
    } catch (error) {
      logger.error("[${ModuleName}Repository] hardDelete failed", error);
      throw handlePrismaError(error);
    }
  },
};
